# Environment: dev | backtest | paper | live
ALGO_TRADER_ENV=paper

# PostgreSQL (provided by ETF trader repo on same VPS)
DB_HOST=trading_postgres
DB_PORT=5432
DB_NAME=trading
DB_USER=trading_writer
DB_PASSWORD=

# IB Gateway
IB_HOST=host.docker.internal
IB_PORT=4002
IB_ACCOUNT_ID=

# IB Client ID (unique per container, override in docker-compose.yml)
# ETF strategies: 1-10, Momentum strategies: 11-20
IB_CLIENT_ID=11

# Trading instrument (NQ for full-size, MNQ for micro)
TRADING_SYMBOL=MNQ

# Instrumentation (sidecar event forwarding)
INSTRUMENTATION_HMAC_SECRET=
INSTRUMENTATION_RELAY_URL=
